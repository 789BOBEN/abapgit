    private _executeApproveAction2(aSelectedItems: any[]): void {
        const oModel = this.getView()?.getModel() as any;
        const oView = this.getView();
        
        if (!oModel) {
            MessageBox.error("数据模型不可用");
            if (oView) {
                oView.setBusy(false);
            }
            return;
        }
        
        if (oView) {
            oView.setBusy(true);
        }
    
        // 启用批量模式
        oModel.setUseBatch(true);
        
        // 清除之前的批量操作
        oModel.resetChanges();
        
        // 为每个选中项创建审批请求
        const aPromises: Promise<void>[] = [];
        
        aSelectedItems.forEach((oItem) => {
            const oContext = oItem.getBindingContext();
            if (!oContext) return;
    
            const sPath = oContext.getPath();
            
            // 创建一个 Promise 来处理单个审批操作
            const oPromise = new Promise<void>((resolve, reject) => {
                // 直接调用 approve 函数
                oModel.callFunction(sPath + "/approve", {
                    method: "POST",
                    success: () => {
                        resolve();
                    },
                    error: (oError: any) => {
                        reject(oError);
                    }
                });
            });
            
            aPromises.push(oPromise);
        });
    
