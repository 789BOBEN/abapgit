 <mvc:View controllerName="prosapui5.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified"
    xmlns:core="sap.ui.core">
    <Page id="idPagePage" title="{i18n>title}">
        <headerContent>
            <Button text="Add" icon="sap-icon://add" press="onAddButtonPress"/>
            <Button text="Approve" icon="sap-icon://accept" press="onApprovePress"/>
            <Button text="Export Excel" icon="sap-icon://excel-attachment" press="onExportExcelPress"/>
            <unified:FileUploader
                id="excelUploader"
                buttonOnly="true"
                buttonText="Import Excel"
                sameFilenameAllowed="true"
                uploadOnChange="false"
                fileType="xlsx,xls"
                change="onImportFileChange"/>
        </headerContent>
        <content>
            <SearchField id="idSearchField" search="onSearchFieldSearch" placeholder="Search by Travel ID" width="100%"/>
            <List id="idZcRapAbookList" mode="Delete" delete="onDeletePress" items="{path: '/ZC_RAP_ABOOK_0309'}">
                <items>
                    <ObjectListItem
                        title="{travel_id}"
                        number="{booking_date}"
                        numberUnit="Booking Date"
                        type="Active"
                        press="onItemPress">
                        <attributes>
                            <ObjectAttribute title="Booking UUID" text="{booking_uuid}"/>
                            <ObjectAttribute title="Travel UUID" text="{travel_uuid}"/>
                        </attributes>
                    </ObjectListItem>
                </items>
                <noData>
                    <Text text="No bookings found"/>
                </noData>
            </List>
        </content>
        <dependents>
            <Dialog id="bookingDialog" title="Booking Details" class="sapUiResponsivePadding">
                <form:SimpleForm id="bookingForm" layout="ResponsiveGridLayout" xmlns:form="sap.ui.layout.form">
                    <form:content>
                        <Label text="Travel ID"/>
                        <Input id="travelIdInput" value="{travel_id}"/>
                        <Label text="Booking Date"/>
                        <DatePicker id="bookingDateInput" value="{booking_date}" valueFormat="yyyy-MM-dd" displayFormat="long"/>
                        <Label text="Travel UUID"/>
                        <Input id="travelUuidInput" value="{travel_uuid}"/>
                    </form:content>
                </form:SimpleForm>
                <beginButton>
                    <Button text="Save" press="onSavePress"/>
                </beginButton>
                <endButton>
                    <Button text="Cancel" press="onCancelPress"/>
                </endButton>
            </Dialog>
        </dependents>
    </Page>
</mvc:View>             











              
